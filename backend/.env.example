# Copy to .env and fill in. The app runs without a key (offline template fallback),
# but Claude-powered drafting/revision/redline needs this set.
ANTHROPIC_API_KEY=

# Models (see docs/architecture.md). Reasoning-heavy work uses Opus; high-volume uses Sonnet.
CONTRACT_MINT_MODEL_REASONING=claude-opus-4-8
CONTRACT_MINT_MODEL_DRAFTING=claude-sonnet-4-6

# Demo tenant (single-tenant demo, multi-tenant schema).
CONTRACT_MINT_DEFAULT_TENANT=demo-merchant

# Where generated DOCX versions are written.
CONTRACT_MINT_STORAGE_DIR=./_storage
