# Copy to .env.local. Base URL of the Contract Mint backend (FastAPI).
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Clerk auth. Create an app at https://dashboard.clerk.com and copy the two keys.
# The publishable key is safe to expose; the secret key must stay private.
# On Replit: put BOTH in Secrets (do NOT commit real values).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_<your-publishable-key>
CLERK_SECRET_KEY=sk_test_<your-secret-key>            # keep private; Replit/Vercel secrets only

# Optional: where Clerk routes to. Defaults work with the /sign-in and /sign-up pages.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
